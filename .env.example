# Neon Postgres connection string (Vercel integration sets this automatically)
DATABASE_URL=postgres://user:password@host/db?sslmode=require

# Secret used by /api/cron/poll to authorize Vercel Cron requests.
# Vercel Cron sends header: Authorization: Bearer ${CRON_SECRET}
CRON_SECRET=change-me

# Optional: tweak HTTP fetching
USER_AGENT="FindcarsellerBot/0.1 (+https://example.com)"
